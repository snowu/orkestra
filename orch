#!/usr/bin/env bash
# Standalone orchestrator binary: control/jump between worktree agents running
# in tmux. Works from bash or zsh via the thin wrapper function in
# orch.sh — that wrapper is what actually cd's the caller's shell; this
# binary only ever prints (on stdout, last line) the directory to cd into,
# if any. All other output goes to stderr so it doesn't get swallowed by the
# wrapper's `$(...)` capture.
set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HELPER="$SCRIPT_DIR/orch-helper.sh"

[[ -f "$HOME/.orch.conf" ]] && source "$HOME/.orch.conf"

# ORCH_CODE_ROOTS / ORCH_WORKTREES_ROOTS: see orch-helper.sh for the full
# explanation — defaults preserve the original ~/code, ~/worktrees layout.
ORCH_CODE_ROOTS=("${ORCH_CODE_ROOTS[@]:-$HOME/code}")
ORCH_WORKTREES_ROOTS=("${ORCH_WORKTREES_ROOTS[@]:-$HOME/worktrees}")

find_repo_root() {
  local repo=$1 root
  for root in "${ORCH_CODE_ROOTS[@]}"; do
    [[ -d "$root/$repo/.git" ]] && { printf '%s' "$root/$repo"; return; }
  done
}

find_worktree() {
  local repo=$1 task=$2 root
  for root in "${ORCH_WORKTREES_ROOTS[@]}"; do
    [[ -d "$root/$repo/$task" ]] && { printf '%s' "$root/$repo/$task"; return; }
  done
}

# new-task is a shell function, normally sourced into an interactive shell —
# orch runs as its own process and never inherits it from the caller, so
# load it directly here too (only new_task() below actually needs it).
[[ -f "$HOME/scripts/worktree-tasks.sh" ]] && source "$HOME/scripts/worktree-tasks.sh"

if ! command -v fzf &>/dev/null; then
  echo "fzf not installed. Run: brew install fzf / apt install fzf" >&2
  exit 1
fi

marker="/tmp/orch-new-task.marker"
rm -f "$marker"
: > /tmp/orch.log

# AGENT (running/waiting) column is push-based: ~/.claude/hooks/orch-agent-state.sh
# writes state directly off Claude Code's own hook events (see
# orch-helper.sh's cached_agent_state). No poller needed here anymore —
# tmux-pane scraping was a race against Claude Code's own repaint and
# unreliable in practice.

help_line="ENTER=attach tmux session (creates one if needed)   ctrl-n=new-task   ctrl-x=end-task   ctrl-k=kill session   ctrl-r=refresh   ?=toggle info panel"
column_header=$(printf "%-16s %-32s %-14s %-8s %-8s %-16s %-9s %s" "REPO" "TASK" "BRANCH" "STATE" "AGENT" "SESSION" "LAST USED" "CMD")
header="$help_line"$'\n'"$column_header"
sel=$("$HELPER" rows | fzf --ansi --layout=reverse --header-first --info=inline --header="$header" \
  --bind "ctrl-n:execute-silent(touch $marker)+abort" \
  --bind "ctrl-x:execute($HELPER confirm-end-task {1} {2})+reload($HELPER rows)" \
  --bind "ctrl-k:execute($HELPER confirm-kill-task {1} {2})+reload($HELPER rows)" \
  --bind "ctrl-r:reload($HELPER rows)" \
  --bind "?:toggle-preview" \
  --preview-window "down,70%,wrap,border-none" \
  --preview "$HELPER split-preview {1} {2}")

# Attach-or-create a tmux session by name. If we're not already inside a
# tmux client, exec straight into it — replaces this process, takes over
# the terminal cleanly, and `new -A` is safe to use here since there's no
# separate client involved. If we ARE already inside tmux, exec'ing would
# try to nest (tmux refuses this by default), so we create-if-needed and
# switch-client instead — but `new -A ... -d` is NOT safe for that: `-A`
# makes new-session behave like attach-session when the session already
# exists, and once that happens `-d` no longer means "start detached" —
# it's reinterpreted as attach-session's "-d" ("detach other clients from
# this session"). That mattered when orch ran inside a tmux popup (its
# own ephemeral client context); the tmux keybind now opens orch in a
# real new-window instead (see keybind-install.sh — window, not popup,
# for a border-free full-screen picker), so switch-client's default "the
# client in use" resolution is just the real client and needs no special
# targeting. Still guard against -A hitting an existing session: check
# first, only create if missing, same as before.
_orch_goto_session() {
  local name=$1 dir=$2
  if [[ -n "${TMUX:-}" ]]; then
    tmux has-session -t "=$name" 2>/dev/null || tmux new -d -s "$name" -c "$dir"
    tmux switch-client -t "$name"
  else
    exec tmux new -A -s "$name" -c "$dir"
  fi
}

# named_session <repo> <task> — echoes the session name orch uses for a
# worktree. Defaults to just the task name — by design, so one agent can
# span multiple repos under the same task (e.g. a BE+FE pair worked on
# together) sharing a single tmux session for context continuity. Tmux
# session names are global, so this intentionally lets same-named tasks
# across repos land in the same session; set ORCH_SCOPE_SESSIONS_TO_REPO=1
# in ~/.orch.conf if you'd rather they never collide.
named_session() {
  local repo=$1 task=$2
  if [[ "${ORCH_SCOPE_SESSIONS_TO_REPO:-0}" == "1" ]]; then
    printf '%s\n' "${repo}__${task}"
  else
    printf '%s\n' "$task"
  fi
}

new_task() {
  if ! declare -f new-task >/dev/null 2>&1; then
    echo "new-task not found. Install ~/scripts/worktree-tasks.sh or source your own." >&2
    return 1
  fi

  # Favorites first (from ~/.orch.conf), rest sorted after.
  local favorites=("${ORCH_FAVORITES[@]:-}")
  local repo d root rest=()

  for root in "${ORCH_CODE_ROOTS[@]}"; do
    for d in "$root"/*/; do
      d=$(basename "$d")
      [[ -d "$root/$d/.git" ]] || continue
      [[ " ${favorites[*]} " == *" $d "* ]] && continue
      rest+=("$d")
    done
  done

  repo=$( { printf '%s\n' "${favorites[@]}"; printf '%s\n' "${rest[@]}" | sort; } | \
    fzf --prompt="repo> " --header="pick a repo (type to filter, tab to select)" +s)
  [[ -z "$repo" ]] && return 1

  local repo_root
  repo_root=$(find_repo_root "$repo")
  [[ -n "$repo_root" ]] || { echo "repo '$repo' not found under any ORCH_CODE_ROOTS" >&2; return 1; }

  local task
  task=$(git -C "$repo_root" branch --format='%(refname:short)' 2>/dev/null | \
    fzf --prompt="new task name> " --header="type new task/branch name (list is existing branches for reference)" \
        --print-query --bind "enter:print-query" | head -1)
  [[ -z "$task" ]] && return 1

  (cd "$repo_root" && new-task "$task") >&2

  local wt
  wt=$(find_worktree "$repo" "$task")
  [[ -n "$wt" ]] || wt="${ORCH_WORKTREES_ROOTS[0]}/$repo/$task"
  local hook_fn="ORCH_HOOK_${repo//[^a-zA-Z0-9]/_}"
  if declare -f "$hook_fn" >/dev/null 2>&1; then
    (cd "$wt" 2>/dev/null && "$hook_fn") >&2
  fi

  # Without this, a freshly created task shows up at the bottom of the list
  # (sorted by last-used-via-orch) the very next time orch runs, even though
  # you're sitting in it right now — landing here counts as using it.
  "$HELPER" touch-access "$repo" "$task"

  [[ -d "$wt" ]] || return 1
  _orch_goto_session "$(named_session "$repo" "$task")" "$wt"
}

if [[ -f "$marker" ]]; then
  rm -f "$marker"
  new_task
  exit 0
fi

[[ -z "$sel" ]] && exit 0

repo=$(echo "$sel" | awk '{print $1}')
task=$(echo "$sel" | awk '{print $2}')
wt=$(find_worktree "$repo" "$task")
[[ -n "$wt" ]] || wt="${ORCH_WORKTREES_ROOTS[0]}/$repo/$task"

# Record "actually landed here via orch" for the LAST USED column — worktree
# mtime only changes on file edits, not on cd/attach, so it drifts from what
# the user actually did. This is the real signal.
"$HELPER" touch-access "$repo" "$task"

# tmux is required — ENTER always attach-or-creates the session for this
# worktree by task name (no separate "idle" cd-only path). See named_session
# and _orch_goto_session above.
_orch_goto_session "$(named_session "$repo" "$task")" "$wt"
